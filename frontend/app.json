{
  "expo": {
    "name": "BBA Tech",
    "slug": "blue-box-air-inc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "blueboxairtech",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "alonzo.cotton",
    "description": "Blue Box Air, Inc. Technician App — Coil management, equipment service readings, project reports, and team collaboration for field technicians.",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blueboxair.techapp",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload photos from your gallery",
        "NSCameraUsageDescription": "Capture photos for equipment documentation",
        "NSLocationWhenInUseUsageDescription": "Track your location for service visits",
        "NSLocationAlwaysUsageDescription": "Track location during service visits",
        "NSFaceIDUsageDescription": "Use Face ID to quickly login to the app",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f2744"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.blueboxair.techapp",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f2744"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Blue Box Air, Inc Tech App to use Face ID for quick login"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#a3e635"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5374137e-6924-4b8b-b7c2-f01b5ca3ac15"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5374137e-6924-4b8b-b7c2-f01b5ca3ac15"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
